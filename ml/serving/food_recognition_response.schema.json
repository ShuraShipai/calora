{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://calora.local/schemas/food-recognition-response-0.1.json",
  "title": "Calora Food Recognition Response",
  "type": "object",
  "required": ["model_version", "items"],
  "properties": {
    "model_version": {"type": "string", "minLength": 1},
    "items": {
      "type": "array",
      "items": {"$ref": "#/$defs/detectedFoodItem"}
    },
    "warnings": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "detectedFoodItem": {
      "type": "object",
      "required": ["detection_id", "label", "display_name", "confidence", "bounding_box", "candidates"],
      "properties": {
        "detection_id": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1},
        "display_name": {"type": "string", "minLength": 1},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "bounding_box": {"$ref": "#/$defs/box"},
        "candidates": {"type": "array", "minItems": 1, "maxItems": 5, "items": {"$ref": "#/$defs/candidate"}},
        "portion_grams": {"type": ["number", "null"], "exclusiveMinimum": 0}
      },
      "additionalProperties": false
    },
    "candidate": {
      "type": "object",
      "required": ["label", "display_name", "score"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "display_name": {"type": "string", "minLength": 1},
        "score": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": false
    },
    "box": {
      "type": "object",
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": {"type": "number", "minimum": 0, "maximum": 1},
        "y": {"type": "number", "minimum": 0, "maximum": 1},
        "width": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
        "height": {"type": "number", "exclusiveMinimum": 0, "maximum": 1}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
